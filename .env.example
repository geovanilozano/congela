# Copia este archivo como .env  ->  cp .env.example .env

# Base de datos (SQLite local). La ruta es relativa a la raíz del proyecto.
DATABASE_URL="file:./prisma/dev.db"

# Clave con la que se firman las sesiones.
# EN LOCAL puedes dejarla así. AL PUBLICAR es OBLIGATORIA y debe ser larga y secreta:
# si no la cambias, cualquiera podría entrar como Dueño.
# Genera una con:  openssl rand -base64 32
AUTH_SECRET="congela-secreto-local-cambialo"

# Opcional: clave de la API de Claude para leer facturas por foto (OCR).
# También se puede configurar desde la pantalla de Ajustes.
# ANTHROPIC_API_KEY=""
