# Copia este archivo como .env  ->  cp .env.example .env

# Base de datos PostgreSQL. En producción usa la cadena de conexión de Neon.
# Ejemplo: postgresql://usuario:clave@host/base?sslmode=require
DATABASE_URL="postgresql://usuario:clave@host:5432/congela?sslmode=require"

# Clave con la que se firman las sesiones y se cifran las credenciales.
# AL PUBLICAR es OBLIGATORIA y debe ser larga y secreta (si no, cualquiera podría entrar
# como Dueño). Genera una con:  openssl rand -base64 32
AUTH_SECRET="congela-secreto-local-cambialo"

# Token de Vercel Blob para guardar las fotos de recibos (solo en producción).
# En desarrollo local puedes dejarlo vacío: las fotos se guardan en la carpeta ./archivos
BLOB_READ_WRITE_TOKEN=""

# Opcional: clave de la API de Claude para leer facturas por foto (OCR).
# También se puede configurar desde la pantalla de Ajustes.
# ANTHROPIC_API_KEY=""

# --- Notificaciones push (opcional) ---
# Genera un par con: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
# Token que protege /api/cron/notificar (el cron externo lo manda como ?token=...)
CRON_SECRET=
