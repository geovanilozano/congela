// Modelo de datos — núcleo financiero de Congela.
// Todos los montos se guardan en CENTAVOS (Int) para evitar errores de redondeo.
// SQLite no soporta enums: los campos "tipo/estado" se guardan como String.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Inversión inicial
// ---------------------------------------------------------------------------
model Inversion {
  id          Int      @id @default(autoincrement())
  descripcion String
  proveedor   String?
  valorCents  Int
  fecha       DateTime @default(now())
  formaPago   String   @default("credito") // "contado" | "credito"
  fotoUrl     String?
  creditoId   Int?
  credito     Credito? @relation(fields: [creditoId], references: [id])
  // Si esta inversión corresponde a un equipo, queda enlazada a su activo.
  // Al borrar el activo, su inversión se borra también (Cascade).
  activoId    Int?     @unique
  activo      Activo?  @relation(fields: [activoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Crédito de la inversión + amortización
// ---------------------------------------------------------------------------
model Credito {
  id            Int                  @id @default(autoincrement())
  entidad       String?
  montoCents    Int
  tasaMensual   Float // 0.02 = 2% mensual
  numCuotas     Int
  fechaInicio   DateTime             @default(now())
  periodicidad  String               @default("mensual")
  estado        String               @default("activo") // "activo" | "pagado"
  cuotas        CuotaAmortizacion[]
  pagos         PagoCredito[]
  inversiones   Inversion[]
  createdAt     DateTime             @default(now())
}

model CuotaAmortizacion {
  id              Int          @id @default(autoincrement())
  creditoId       Int
  credito         Credito      @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  numero          Int
  fechaVencimiento DateTime
  cuotaCents      Int
  capitalCents    Int
  interesCents    Int
  saldoCents      Int
  // Cuánto se ha abonado de esta cuota (permite pagos parciales). Cuando llega a
  // cuotaCents, la cuota queda "pagada".
  abonadoCents    Int          @default(0)
  estado          String       @default("pendiente") // "pendiente" | "parcial" | "pagada" | "vencida"
  pago            PagoCredito?

  @@index([creditoId])
}

model PagoCredito {
  id         Int                @id @default(autoincrement())
  creditoId  Int
  credito    Credito            @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  cuotaId    Int?               @unique
  cuota      CuotaAmortizacion? @relation(fields: [cuotaId], references: [id])
  valorCents Int
  fecha      DateTime           @default(now())
  comprobanteUrl String?

  @@index([creditoId])
}

// ---------------------------------------------------------------------------
// Distribución del dinero (fondos / "bolsillos")
// ---------------------------------------------------------------------------
model Fondo {
  id           Int               @id @default(autoincrement())
  nombre       String            @unique
  regla        ReglaReparto?
  movimientos  MovimientoFondo[]
}

model ReglaReparto {
  id         Int    @id @default(autoincrement())
  fondoId    Int    @unique
  fondo      Fondo  @relation(fields: [fondoId], references: [id], onDelete: Cascade)
  tipo       String // "fijo" | "porcentaje" | "resto"
  valorCents Int?   // para "fijo"
  valor      Float? // para "porcentaje" (0.1 = 10%)
  prioridad  Int    @default(10)
  activo     Boolean @default(true)
}

model MovimientoFondo {
  id          Int         @id @default(autoincrement())
  fondoId     Int
  fondo       Fondo       @relation(fields: [fondoId], references: [id], onDelete: Cascade)
  montoCents  Int // positivo entra, negativo sale
  concepto    String
  fecha       DateTime    @default(now())
  cierreId    Int?
  cierre      CierreCaja? @relation(fields: [cierreId], references: [id])

  @@index([fondoId])
  @@index([cierreId])
  @@index([fecha])
}

// ---------------------------------------------------------------------------
// Ventas y cierre de caja
// ---------------------------------------------------------------------------
model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  telefono  String?
  cedula    String?
  correo    String?
  tipo      String   @default("contado") // "contado" | "credito"
  ventas    Venta[]
  medidores MedidorCliente[]
  createdAt DateTime @default(now())

  @@index([nombre])
}

model Venta {
  id         Int         @id @default(autoincrement())
  clienteId  Int?
  cliente    Cliente?    @relation(fields: [clienteId], references: [id])
  fecha      DateTime    @default(now())
  totalCents Int
  formaPago  String      @default("contado") // "contado" | "credito"
  // Cobro del fiado: una venta a crédito nace por cobrar (pagada=false) hasta que el
  // cliente paga. El contado nace pagado. Es contabilidad de cuentas por cobrar; no
  // cambia el reparto del dinero (el fiado ya entra al cierre).
  pagada     Boolean     @default(false)
  pagadaEn   DateTime?
  fotoUrl    String?
  items      VentaItem[]
  cierreId   Int?
  cierre     CierreCaja? @relation(fields: [cierreId], references: [id])

  @@index([fecha])
  @@index([cierreId])
  @@index([clienteId])
}

model VentaItem {
  id             Int    @id @default(autoincrement())
  ventaId        Int
  venta          Venta  @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  descripcion    String
  cantidad       Int
  precioUnitCents Int
  subtotalCents  Int

  @@index([ventaId])
}

model CierreCaja {
  id           Int               @id @default(autoincrement())
  fecha        DateTime          @default(now())
  totalCents   Int
  ventas       Venta[]
  movimientos  MovimientoFondo[]
  createdAt    DateTime          @default(now())
}

// ---------------------------------------------------------------------------
// Energía y servicios
// ---------------------------------------------------------------------------
model EnergiaGeneracion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now())
  kwh       Float // energía generada por los paneles ese día
  fuente    String   @default("manual") // "manual" | "api"
  createdAt DateTime @default(now())

  @@index([fecha])
}

model MedidorLectura {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now())
  kwh       Float // consumo de la empresa ese día
  fuente    String   @default("manual") // "manual" | "api"
  createdAt DateTime @default(now())

  @@index([fecha])
}

model ReciboServicio {
  id            Int      @id @default(autoincrement())
  tipo          String // "energia" | "agua" | "gas" | "internet"
  periodoInicio DateTime?
  periodoFin    DateTime?
  consumo       Float? // kWh, m3, etc. (según el servicio)
  valorCents    Int
  fotoUrl       String?
  fecha         DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([fecha])
  @@index([tipo])
}

// Ajustes clave/valor del sistema (ej. precio del kWh).
model Ajuste {
  clave String @id
  valor String
}

// ---------------------------------------------------------------------------
// Usuarios y roles (login local)
// ---------------------------------------------------------------------------
model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  usuario      String   @unique
  passwordHash String
  rol          String   @default("dueno") // dueno | cajero | operario
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// Bitácora de acciones sensibles: quién hizo qué y cuándo. En un negocio de caja con
// varios usuarios es lo que permite rendir cuentas, resolver dudas ("¿quién borró esa
// venta?") y detectar errores o fraude.
//
// El nombre del usuario se guarda COPIADO (no solo el id) para que el registro siga
// siendo legible aunque después se elimine o renombre ese usuario.
model RegistroAuditoria {
  id            Int      @id @default(autoincrement())
  usuarioId     Int?
  usuarioNombre String
  rol           String?
  accion        String // crear | actualizar | eliminar | cerrar | anular | restaurar
  entidad       String // venta | cierre | credito | empleado | gasto | usuario | datos
  entidadId     Int?
  detalle       String? // resumen legible, ej. "Venta #12 · $30.000"
  fecha         DateTime @default(now())

  @@index([fecha])
  @@index([entidad])
}

// ---------------------------------------------------------------------------
// Operación: activos, producción, inventario, compras/gastos
// ---------------------------------------------------------------------------
model Activo {
  id            Int          @id @default(autoincrement())
  nombre        String
  tipo          String       @default("otro") // cubetero, refrigerador, panel, inversor, medidor, picadora, otro
  marca         String?
  capacidad     String?
  consumoKwh    Float?
  costoCents    Int          @default(0)
  fechaCompra   DateTime?
  garantiaHasta DateTime?
  estado         String          @default("activo") // activo, mantenimiento, dañado, baja
  ubicacion      String?
  producciones   Produccion[]
  mantenimientos Mantenimiento[]
  inversion      Inversion?
  createdAt      DateTime        @default(now())
}

model Produccion {
  id         Int       @id @default(autoincrement())
  fecha      DateTime  @default(now())
  turno      String? // mañana, tarde, noche
  tipo       String    @default("cubo") // cubo, picado
  bolsas     Int       @default(0)
  kilos      Float?
  perdidas   Int       @default(0)
  activoId   Int?
  activo     Activo?   @relation(fields: [activoId], references: [id])
  empleadoId Int?
  empleado   Empleado? @relation(fields: [empleadoId], references: [id])
  nota       String?
  createdAt  DateTime  @default(now())

  @@index([fecha])
  @@index([activoId])
  @@index([empleadoId])
}

model InsumoInventario {
  id          Int                    @id @default(autoincrement())
  nombre      String                 @unique
  unidad      String                 @default("unidad") // unidad, bolsa, kg, litro
  stock       Float                  @default(0)
  stockMinimo Float                  @default(0)
  movimientos MovimientoInventario[]
  createdAt   DateTime               @default(now())
}

model MovimientoInventario {
  id        Int              @id @default(autoincrement())
  insumoId  Int
  insumo    InsumoInventario @relation(fields: [insumoId], references: [id], onDelete: Cascade)
  cantidad  Float // + entrada, - salida
  concepto  String
  fecha     DateTime         @default(now())

  @@index([insumoId])
  @@index([fecha])
}

model CompraGasto {
  id          Int      @id @default(autoincrement())
  categoria   String // bolsas, mantenimiento, nomina, transporte, arriendo, servicios, reparaciones, impuestos, otro
  descripcion String
  proveedor   String?
  valorCents  Int
  fecha       DateTime @default(now())
  fotoUrl     String?
  createdAt   DateTime @default(now())

  @@index([fecha])
  @@index([categoria])
}

// ---------------------------------------------------------------------------
// Personal y mantenimiento
// ---------------------------------------------------------------------------
model Empleado {
  id            Int           @id @default(autoincrement())
  nombre        String
  cargo         String?
  telefono      String?
  salarioCents  Int           @default(0)
  fechaIngreso  DateTime?
  activo        Boolean       @default(true)
  asistencias   Asistencia[]
  pagos         PagoNomina[]
  producciones  Produccion[]
  createdAt     DateTime      @default(now())
}

model Asistencia {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha      DateTime @default(now())
  turno      String?
  estado     String   @default("presente") // presente | ausente | tarde
  horas      Float?

  @@index([empleadoId])
  @@index([fecha])
}

model PagoNomina {
  id             Int      @id @default(autoincrement())
  empleadoId     Int
  empleado       Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha          DateTime @default(now())
  valorCents     Int
  concepto       String   @default("Salario")
  comprobanteUrl String?

  @@index([empleadoId])
  @@index([fecha])
}

model Mantenimiento {
  id              Int       @id @default(autoincrement())
  activoId        Int?
  activo          Activo?   @relation(fields: [activoId], references: [id])
  tipo            String    @default("preventivo") // preventivo | correctivo
  descripcion     String
  fechaProgramada DateTime
  fechaRealizada  DateTime?
  costoCents      Int       @default(0)
  estado          String    @default("programado") // programado | realizado
  nota            String?
  createdAt       DateTime  @default(now())

  @@index([activoId])
  @@index([fechaProgramada])
}

// ---------------------------------------------------------------------------
// Sub-medición: medidores instalados a clientes (se les revende energía) y la
// liquidación de cada periodo, calcada de cómo cobra el operador de red (ESSA).
// ---------------------------------------------------------------------------
model MedidorCliente {
  id            Int                  @id @default(autoincrement())
  clienteId     Int?
  cliente       Cliente?             @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  numero        String
  marca         String?
  direccion     String?
  factor        Int                  @default(1) // factor de multiplicación del medidor
  nota          String?
  activo        Boolean              @default(true)
  liquidaciones LiquidacionMedidor[]
  createdAt     DateTime             @default(now())

  @@index([clienteId])
}

model LiquidacionMedidor {
  id                  Int            @id @default(autoincrement())
  medidorId           Int
  medidor             MedidorCliente @relation(fields: [medidorId], references: [id], onDelete: Cascade)
  fechaAnterior       DateTime
  fechaActual         DateTime
  lecturaAnterior     Float          // kWh (el medidor puede marcar decimales)
  lecturaActual       Float          // kWh
  factor              Int            @default(1) // se copia del medidor: la liquidación es inmutable
  fotoUrl             String?
  tarifaCuCents       Int            // centavos de peso por kWh (ej. 824.03 $/kWh -> 82403)
  // Subsidio: % del extracto aplicado SOLO al consumo de subsistencia (así lo cobra ESSA).
  subsidioPct         Float          @default(0) // % del extracto (ej. 47, 50)
  subsistenciaKwh     Int            @default(173) // tope de kWh subsidiados (Barrancabermeja ~173)
  // Si varios medidores comparten el MISMO recibo de ESSA: consumo total del recibo. El
  // subsidio del recibo (uno solo) se reparte entre los medidores proporcional a su consumo.
  // 0 = este medidor es el único del recibo (el subsidio se aplica completo a su consumo).
  consumoTotalKwh     Int            @default(0)
  // Alumbrado público: valor TOTAL del extracto; el cliente paga un % (así se reparte
  // entre varios medidores). El valor del recibo ya viene siendo ~6% de la energía.
  alumbradoTotalCents Int            @default(0)
  alumbradoPct        Float          @default(50) // % del alumbrado total que paga el cliente
  // Aseo: cargo fijo del extracto; el cliente paga un % (opcional).
  aseoTotalCents      Int            @default(0)
  aseoPct             Float          @default(0)
  pagada              Boolean        @default(false)
  pagadaEn            DateTime?
  createdAt           DateTime       @default(now())

  @@index([medidorId])
}

// Suscripción de un dispositivo a las notificaciones push (Web Push / VAPID).
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
