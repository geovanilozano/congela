# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...menos la plantilla, que sí se versiona (el README pide copiarla)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# prisma sqlite database (local)
*.db
*.db-journal
prisma/dev.db*

# fotos de recibos/facturas subidas: carpeta PRIVADA, se sirven por /api/archivo
/archivos
# (carpeta antigua, cuando las fotos eran públicas)
/public/uploads/*
!/public/uploads/.gitkeep

# artefactos de pruebas con navegador
/.playwright-mcp
